# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=smartvenue
DATABASE_URL=postgresql://postgres:password@postgres:5432/smartvenue?schema=public

# Redis
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=supersecret
JWT_REFRESH_SECRET=superrefreshsecret

# Stripe (Provide your test keys here)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Web Push (Generate these later using web-push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@smartvenue.local

# Web Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
